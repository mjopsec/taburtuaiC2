# ── Compiled binaries ─────────────────────────────────────────
*.exe
*.dll
*.so
*.dylib
*.out
bin/

# ── Built agents / payloads ───────────────────────────────────
builder/output/
output/
builds/
loot/
backups/
*.bin
*.shellcode
*.payload
*.hta
*.vba
*.lnk

# ── Tools output ──────────────────────────────────────────────
tools/*.docx
tools/*.pdf

# ── Runtime data ──────────────────────────────────────────────
data/
*.db
*.db-shm
*.db-wal

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
*.log.*
security.log

# ── Secrets / keys ────────────────────────────────────────────
.env
.env.*
*.key
*.pem
*.p12
*.pfx
taburtuai.json
certs/

# ── Config overrides (keep template, ignore local overrides) ──
config/local*.yaml
config/*.local.yaml

# ── Go toolchain ──────────────────────────────────────────────
vendor/

# ── Python artifacts ──────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── OS junk ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Temp / runtime artifacts ──────────────────────────────────
*.tmp
modules/

# ── Test artifacts ────────────────────────────────────────────
coverage.out
*.test

# ── Web UI (Vue/Vite) ─────────────────────────────────────────
web/node_modules/
web/dist/
web/.vite/
web/*.local
